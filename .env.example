# ==========================================
# Plantilla de variables de entorno
# Copiar a .env y rellenar con valores reales.
# .env NUNCA debe commitearse (ya esta en .gitignore).
# ==========================================

# ---------- BASE DE DATOS ----------
# Postgres local:
DATABASE_URL=postgresql://postgres:CHANGEME@localhost:5432/emergencias_vehiculares
# Produccion (AWS RDS, ejemplo):
# DATABASE_URL=postgresql://USER:PASS@HOST.rds.amazonaws.com:5432/postgres

# Importante: en produccion siempre False. El schema se gestiona con Alembic
# (alembic upgrade head).
AUTO_CREATE_TABLES=False

# ---------- SEGURIDAD ----------
SECRET_KEY=CAMBIAR_EN_PRODUCCION_minimo_32_caracteres_aleatorios
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ---------- APP ----------
APP_NAME=Emergencias Vehiculares API
DEBUG=True

# Origenes permitidos por CORS (separados por coma). En DEBUG, * es aceptable.
# En produccion: lista exacta de dominios (sin protocolo wildcard).
CORS_ORIGINS=http://localhost:4200,http://localhost:3000

# ---------- MULTI-TENANT (Fase 1) ----------
# Si True, todo request debe traer JWT con id_tenant valido.
# Para periodo de transicion se puede dejar en False y endpoint-por-endpoint.
TENANT_ENFORCEMENT=False

# ---------- CLOUDINARY ----------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---------- AWS / BEDROCK ----------
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.amazon.nova-pro-v1:0

# ---------- GOOGLE GEMINI ----------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview

# ---------- FIREBASE ----------
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# ---------- STRIPE ----------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---------- REDIS (Fase 0 opcional, requerido para WS / cache) ----------
# Si vacio, el codigo cae en modo "sin cache" sin romper.
REDIS_URL=
